---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroSection from '../components/HeroSection.astro';
import SpeakerCard from '../components/SpeakerCard.astro';
import SponsorsSection from '../components/SponsorsSection.astro';
import { getCollection } from 'astro:content';

const speakers = await getCollection('speakers');
const sponsors = await getCollection('sponsors');
const schedule = await getCollection('schedule');

type Speaker = (typeof speakers)[number];
type Schedule = (typeof schedule)[number];

// Featured speakers: all keynotes
const keynotes = speakers.filter((s: Speaker) => s.data.sessionType === 'keynote').sort((a: Speaker, b: Speaker) => a.data.day - b.data.day);
// Other speakers for overview
const otherSpeakers = speakers.filter((s: Speaker) => s.data.sessionType !== 'keynote').sort((a: Speaker, b: Speaker) => a.data.day - b.data.day);

const scheduleByDay = [...schedule].sort((a: Schedule, b: Schedule) => a.data.day - b.data.day);
---

<BaseLayout
  title="28th EMBL PhD Symposium 2026 — Shifting Gears to Scale up Discovery"
  description="The 28th EMBL PhD Symposium: Shifting Gears to Scale up Discovery. November 5–7, 2026 at EMBL Heidelberg."
>
  <HeroSection />

  <!-- ── About / Theme Section ─────────────────────────────── -->
  <section class="py-24 lg:py-32 bg-parchment clip-diagonal-down">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <!-- Left: text -->
        <div>
          <div class="flex items-center gap-3 mb-6">
            <div class="h-px w-10 bg-red-600"></div>
            <span class="label-tag text-red-600">About the Symposium</span>
          </div>
          <h2 class="font-display font-800 text-ink text-4xl lg:text-5xl mb-6 leading-[1.05]">
            Biology at a <br />new scale
          </h2>
          <div class="font-body text-muted text-lg leading-relaxed space-y-4">
            <p>
              The 28th EMBL PhD Symposium invites scientists at the frontier of scale — from single-molecule
              imaging to genome-wide perturbation screens, from individual cells to tissue-level spatial atlases,
              from single datasets to population-scale biobanks.
            </p>
            <p>
              Over three focused days, we bring together leading researchers to explore how technology, computation,
              and bold scientific vision are shifting biology into a new era of discovery — one where scale itself
              is the instrument.
            </p>
          </div>

          <!-- Key stats -->
          <div class="grid grid-cols-3 gap-6 mt-10 pt-8 border-t border-warm">
            {[
              { value: '9', label: 'Invited Speakers' },
              { value: '3', label: 'Focused Days'     },
              { value: '200+', label: 'Participants'  },
            ].map(({ value, label }) => (
              <div>
                <p class="font-display font-800 text-green-800 text-4xl mb-1">{value}</p>
                <p class="font-mono text-[0.65rem] tracking-[0.12em] uppercase text-muted">{label}</p>
              </div>
            ))}
          </div>
        </div>

        <!-- Right: day cards -->
        <div class="space-y-4">
          {scheduleByDay.map((day) => (
            <a
              href={`/program#day-${day.data.day}`}
              class="day-preview-card group block"
            >
              <div class="flex items-center justify-between">
                <div class="flex items-center gap-4">
                  <span
                    class="font-display font-800 text-3xl"
                    style={`color: ${day.data.color};`}
                  >
                    {String(day.data.day).padStart(2, '0')}
                  </span>
                  <div>
                    <p class="font-display font-700 text-ink text-lg group-hover:text-green-800 transition-colors">
                      {day.data.title}
                    </p>
                    <p class="font-body text-sm text-muted">{day.data.theme}</p>
                  </div>
                </div>
                <svg class="w-5 h-5 text-muted group-hover:text-green-700 group-hover:translate-x-1 transition-all" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                </svg>
              </div>
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ── Keynote Speakers Section ──────────────────────────── -->
  <section class="py-24 lg:py-32 bg-green-900 clip-both-diagonal">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <!-- Header -->
      <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-14">
        <div>
          <div class="flex items-center gap-3 mb-4">
            <div class="h-px w-10 bg-green-500"></div>
            <span class="label-tag text-green-400">Keynote Lectures</span>
          </div>
          <h2 class="font-display font-800 text-white text-4xl lg:text-5xl">
            Keynote<br />Speakers
          </h2>
        </div>
        <a
          href="/speakers"
          class="self-start md:self-auto font-display font-700 text-sm px-6 py-3 border border-green-500/50 text-green-400 hover:bg-green-500/10 transition-colors"
        >
          All Speakers →
        </a>
      </div>

      <!-- Keynote grid -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-12">
        {keynotes.map((speaker: Speaker) => (
          <SpeakerCard
            slug={speaker.id}
            name={speaker.data.name}
            role={speaker.data.role}
            institution={speaker.data.institution}
            country={speaker.data.country}
            topic={speaker.data.topic}
            day={speaker.data.day}
            sessionType={speaker.data.sessionType}
            image={speaker.data.image}
          />
        ))}
      </div>

      <!-- Other speakers compact row -->
      <div>
        <p class="font-mono text-[0.6rem] tracking-[0.2em] text-white/40 uppercase mb-4">Invited Talks</p>
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-4">
          {otherSpeakers.map((speaker: Speaker) => (
            <a
              href={`/speakers#${speaker.id}`}
              class="group text-center p-4 border border-white/10 hover:border-green-500/40 hover:bg-white/5 transition-all"
            >
              <!-- Initials avatar -->
              <div class="w-12 h-12 mx-auto mb-3 rounded-full bg-green-800/60 flex items-center justify-center">
                <span class="font-display font-800 text-white/50 text-sm">
                  {speaker.data.name.split(' ').map((p: string) => p[0]).join('').slice(0, 2)}
                </span>
              </div>
              <p class="font-display font-600 text-white text-sm leading-tight group-hover:text-green-400 transition-colors">
                {speaker.data.name.split(' ').slice(-1)[0]}
              </p>
              <p class="font-mono text-[0.55rem] tracking-[0.1em] text-white/40 uppercase mt-1">
                Day {speaker.data.day}
              </p>
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ── Key Dates Section ─────────────────────────────────── -->
  <section class="py-24 lg:py-32 bg-parchment">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">
        <!-- Key dates -->
        <div>
          <div class="flex items-center gap-3 mb-8">
            <div class="h-px w-10 bg-red-600"></div>
            <span class="label-tag text-red-600">Important Dates</span>
          </div>
          <h2 class="font-display font-800 text-ink text-4xl mb-10">Mark Your<br />Calendar</h2>
          <div class="space-y-0">
            {[
              { date: 'July 1, 2026',    label: 'Abstract Submission Opens',  past: false },
              { date: 'August 31, 2026', label: 'Abstract Submission Closes', past: false },
              { date: 'September 15, 2026', label: 'Registration Deadline',  past: false },
              { date: 'October 1, 2026', label: 'Program Announced',         past: false },
              { date: 'November 5, 2026', label: 'Symposium Begins',         past: false, highlight: true },
              { date: 'November 7, 2026', label: 'Symposium Ends',           past: false },
            ].map(({ date, label, highlight }, i) => (
              <div class:list={['date-row', highlight ? 'date-row-highlight' : '']}>
                <div class="date-marker">
                  <span class="font-mono font-600 text-xs text-muted">{String(i + 1).padStart(2, '0')}</span>
                </div>
                <div class="flex-1">
                  <p class:list={['font-display font-700 text-base', highlight ? 'text-red-600' : 'text-ink']}>
                    {label}
                  </p>
                  <p class="font-mono text-xs text-muted">{date}</p>
                </div>
                {highlight && <span class="session-badge badge-keynote text-[0.6rem]">Featured</span>}
              </div>
            ))}
          </div>
        </div>

        <!-- Venue teaser -->
        <div class="flex flex-col justify-center">
          <div
            class="relative overflow-hidden bg-green-800 p-10 lg:p-12"
            style="background: linear-gradient(135deg, #1A5C36 0%, #0D3321 100%);"
          >
            <!-- Gear decoration -->
            <img
              src="/gear3.svg"
              alt=""
              aria-hidden="true"
              class="absolute -bottom-8 -right-8 w-48 gear-spin-slow"
              style="filter: invert(1) opacity(0.07);"
            />
            <div class="relative">
              <div class="flex items-center gap-3 mb-6">
                <div class="h-px w-8 bg-green-400"></div>
                <span class="label-tag text-green-400">Venue</span>
              </div>
              <h3 class="font-display font-800 text-white text-3xl mb-4 leading-tight">
                EMBL Heidelberg
              </h3>
              <p class="font-body text-white/70 mb-6 leading-relaxed">
                Set in the wooded hills above Heidelberg, EMBL's main campus is home to
                world-class research facilities and a vibrant international community.
                The ATC Auditorium seats 500 and provides state-of-the-art conference facilities.
              </p>
              <div class="space-y-2 mb-8">
                {[
                  'Meyerhofstraße 1, 69117 Heidelberg',
                  '15 min from Heidelberg city centre',
                  'On-campus accommodation available',
                ].map(info => (
                  <p class="font-mono text-xs text-white/50 flex items-center gap-2">
                    <span class="text-green-400">→</span> {info}
                  </p>
                ))}
              </div>
              <a
                href="/about#venue"
                class="inline-flex items-center gap-2 font-display font-700 text-sm text-green-400 border border-green-400/30 px-6 py-3 hover:bg-green-400/10 transition-colors"
              >
                Travel Info
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                </svg>
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Sponsors Section ──────────────────────────────────── -->
  <SponsorsSection sponsors={sponsors} />
</BaseLayout>

<style>
  .day-preview-card {
    border: 1px solid #E8E4DC;
    background: white;
    padding: 1.5rem;
    transition: border-color 0.2s, box-shadow 0.2s;
  }
  .day-preview-card:hover {
    border-color: #52B788;
    box-shadow: 0 4px 16px rgba(26, 92, 54, 0.08);
  }

  .date-row {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0.875rem 0;
    border-bottom: 1px solid #E8E4DC;
  }
  .date-row:last-child { border-bottom: none; }
  .date-row-highlight {
    background: #FFF5F5;
    margin: 0 -1.5rem;
    padding: 0.875rem 1.5rem;
    border-color: #FFE5E7;
  }
  .date-marker {
    width: 2rem;
    text-align: center;
    flex-shrink: 0;
  }
</style>
