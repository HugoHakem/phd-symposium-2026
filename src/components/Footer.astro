---
const base = import.meta.env.BASE_URL;
const currentYear = new Date().getFullYear();

const footerLinks = [
  {
    heading: 'Symposium',
    links: [
      { href: base,                      label: 'Home'    },
      { href: `${base}program`,          label: 'Program' },
      { href: `${base}speakers`,         label: 'Speakers'},
      { href: `${base}about`,            label: 'About'   },
    ],
  },
  {
    heading: 'Information',
    links: [
      { href: `${base}about#venue`,         label: 'Venue'        },
      { href: `${base}about#travel`,        label: 'Travel'       },
      { href: `${base}about#accommodation`, label: 'Accommodation'},
      { href: `${base}about#faq`,           label: 'FAQ'          },
    ],
  },
  {
    heading: 'Contact',
    links: [
      { href: 'mailto:phdsymposium2026.participants@embl.de', label: 'Participants'    },
      { href: 'mailto:phdsymposium2026.speakers@embl.de',     label: 'Speakers'       },
      { href: 'mailto:phdsymposium2026.partners@embl.de',     label: 'Sponsors'       },
    ],
  },
  {
    heading: 'Follow Us',
    links: [
      { href: 'https://linkedin.com/company/embl/',            label: 'LinkedIn'       },
      { href: 'https://bsky.app/profile/embl.org',             label: 'Bluesky'        },
      { href: 'https://x.com/embl',                            label: 'X (Twitter)'    },
      { href: 'https://www.instagram.com/embl_org/',           label: 'Instagram'      },
    ],
  },
];
---

<footer class="bg-green-900 text-white">
  <!-- Top area with gears and key info -->
  <div class="relative overflow-hidden">
    <img
      src={`${base}gear2.svg`}
      alt=""
      aria-hidden="true"
      class="absolute -top-8 -right-16 w-72 pointer-events-none select-none"
      style="filter: invert(1) opacity(0.05);"
    />

    <div class="max-w-7xl mx-auto px-6 lg:px-8 pt-16 pb-12">
      <!-- Brand + Description -->
      <div class="grid grid-cols-2 lg:grid-cols-5 gap-8">
        <!-- Brand column -->
        <div class="col-span-2 lg:col-span-1">
          <div class="flex items-center gap-3 mb-4">
            <img src={`${base}gear1.svg`} alt="Gear" class="w-8 h-8" style="filter: invert(1) opacity(0.7);" />
            <div>
              <p class="font-display font-800 text-white text-sm">EMBL PhD</p>
              <p class="font-mono text-white/40 text-[0.55rem] tracking-[0.15em] uppercase">Symposium 2026</p>
            </div>
          </div>
          <p class="font-display font-700 text-green-400 text-2xl leading-tight mb-3">
            Shifting Gears:<br />Automation, AI, and<br />High-Throughput Methodologies
          </p>
          <p class="font-mono text-white/50 text-xs leading-relaxed">
            December 1–3, 2026<br />
            EMBL Heidelberg, Germany
          </p>
        </div>

        <!-- Nav columns -->
        {footerLinks.map(({ heading, links }) => (
          <div>
            <h4 class="font-mono text-[0.6rem] tracking-[0.2em] uppercase text-white/40 mb-4">{heading}</h4>
            <ul class="space-y-2">
              {links.map(({ href, label }) => (
                <li>
                  <a
                    href={href}
                    class="font-body text-sm text-white/70 hover:text-white transition-colors underline-animate"
                    target={href.startsWith('http') || href.startsWith('mailto') ? '_blank' : undefined}
                    rel={href.startsWith('http') ? 'noopener noreferrer' : undefined}
                  >
                    {label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- Red accent bar -->
  <div class="h-1 bg-gradient-to-r from-red-700 via-red-500 to-red-700"></div>

  <!-- Bottom bar -->
  <div class="bg-green-950">
    <div class="max-w-7xl mx-auto px-6 lg:px-8 py-5 flex flex-col sm:flex-row items-center justify-between gap-3">
      <p class="font-mono text-[0.6rem] tracking-[0.1em] text-white/30 uppercase">
        &copy; {currentYear} EMBL PhD Students Association · All rights reserved
      </p>
      <div class="flex items-center gap-4">
        <a href={`${base}about#code-of-conduct`} class="font-mono text-[0.6rem] tracking-[0.1em] text-white/30 hover:text-white/60 uppercase transition-colors">
          Code of Conduct
        </a>
        <span class="text-white/20">·</span>
        <a href={"https://www.embl.org/info/privacy-policy/"} class="font-mono text-[0.6rem] tracking-[0.1em] text-white/30 hover:text-white/60 uppercase transition-colors">
          Privacy Policy
        </a>
      </div>
    </div>
  </div>
</footer>
