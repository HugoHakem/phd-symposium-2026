---
const base = import.meta.env.BASE_URL;

// paths relative to base (no leading slash)
const navLinks = [
  { path: '',          label: 'Home'     },
  { path: 'program',   label: 'Program'  },
  { path: 'speakers',  label: 'Speakers' },
  { path: 'about',     label: 'About'    },
];

const currentPath = Astro.url.pathname;

function isActive(path: string): boolean {
  const href = base + path;
  if (path === '') return currentPath === href || currentPath === href.slice(0, -1);
  return currentPath.startsWith(href);
}
---

<header id="site-nav" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300">
  <!-- Background overlay (toggled via JS on scroll) -->
  <div id="nav-bg" class="absolute inset-0 bg-green-800/0 backdrop-blur-0 transition-all duration-300"></div>

  <div class="relative max-w-7xl mx-auto px-6 lg:px-8 flex items-center justify-between h-16 lg:h-20">
    <!-- Logo -->
    <a href={base} class="flex items-center gap-3 group">
      <div class="relative w-9 h-9 flex-shrink-0">
        <img
          src={`${base}gear1.svg`}
          alt="Gear logo"
          class="w-full h-full object-contain transition-transform duration-700 group-hover:rotate-45"
          style="filter: invert(1) brightness(2) opacity(0.9);"
        />
      </div>
      <div class="leading-none">
        <p class="font-display font-800 text-white text-sm tracking-tight">EMBL PhD</p>
        <p class="font-mono text-white/60 text-[0.6rem] tracking-[0.15em] uppercase">Symposium 2026</p>
      </div>
    </a>

    <!-- Desktop nav -->
    <nav class="hidden md:flex items-center gap-1">
      {navLinks.map(({ path, label }) => (
        <a
          href={base + path}
          class:list={[
            'font-display font-600 text-sm px-4 py-2 rounded transition-all duration-200',
            isActive(path)
              ? 'text-white bg-white/15'
              : 'text-white/80 hover:text-white hover:bg-white/10',
          ]}
        >
          {label}
        </a>
      ))}
      <a
        href={`${base}program#registration`}
        class="ml-4 font-display font-700 text-sm px-5 py-2.5 bg-red-600 text-white rounded hover:bg-red-700 transition-colors duration-200"
      >
        Register
      </a>
    </nav>

    <!-- Mobile hamburger -->
    <button
      id="mobile-menu-btn"
      aria-label="Toggle menu"
      class="md:hidden text-white p-2"
    >
      <svg id="icon-open" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
      <svg id="icon-close" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </div>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="hidden md:hidden bg-green-900 border-t border-white/10"
  >
    <nav class="flex flex-col px-6 py-4 gap-1">
      {navLinks.map(({ path, label }) => (
        <a
          href={base + path}
          class:list={[
            'font-display font-600 text-base px-4 py-3 rounded transition-colors',
            isActive(path)
              ? 'text-white bg-white/15'
              : 'text-white/80 hover:text-white hover:bg-white/10',
          ]}
        >
          {label}
        </a>
      ))}
      <a
        href={`${base}program#registration`}
        class="mt-2 font-display font-700 text-base px-4 py-3 bg-red-600 text-white rounded text-center hover:bg-red-700 transition-colors"
      >
        Register
      </a>
    </nav>
  </div>
</header>

<script>
  const nav = document.getElementById('site-nav');
  const navBg = document.getElementById('nav-bg');
  const mobileBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('icon-open');
  const iconClose = document.getElementById('icon-close');

  // Scroll-based nav styling
  function updateNav() {
    const scrolled = window.scrollY > 60;
    if (navBg) {
      navBg.style.backgroundColor = scrolled ? 'rgba(13, 51, 33, 0.95)' : 'rgba(13, 51, 33, 0)';
      navBg.style.backdropFilter = scrolled ? 'blur(12px)' : 'blur(0)';
    }
    if (nav) {
      nav.style.borderBottom = scrolled ? '1px solid rgba(255,255,255,0.08)' : 'none';
    }
  }

  window.addEventListener('scroll', updateNav, { passive: true });
  updateNav();

  // Mobile menu toggle
  mobileBtn?.addEventListener('click', () => {
    const isOpen = !mobileMenu?.classList.contains('hidden');
    mobileMenu?.classList.toggle('hidden', isOpen);
    iconOpen?.classList.toggle('hidden', !isOpen);
    iconClose?.classList.toggle('hidden', isOpen);
  });
</script>
