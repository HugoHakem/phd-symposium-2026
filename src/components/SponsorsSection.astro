---
interface Sponsor {
  id: string;
  data: {
    name: string;
    tier: 'sponsor' | 'grant' | 'cpp';
    subTier?: 'founder_partner' | 'corporate_partner' | 'associate_partner';
    website?: string;
    description: string;
    logo?: string;
  };
}

interface Props {
  sponsors: Sponsor[];
}

const { sponsors } = Astro.props;

const mainSponsors = sponsors.filter(s => s.data.tier === 'sponsor');
const grants       = sponsors.filter(s => s.data.tier === 'grant');
const cppSponsors  = sponsors.filter(s => s.data.tier === 'cpp');

const cppSubTiers = [
  { key: 'founder_partner',   label: 'Founder Partners'    },
  { key: 'corporate_partner', label: 'Corporate Partners'  },
  { key: 'associate_partner', label: 'Associate Partners'  },
] as const;

const cppGrouped = Object.fromEntries(
  cppSubTiers.map(({ key }) => [key, cppSponsors.filter(s => s.data.subTier === key)])
);
---

<section class="py-24 lg:py-32 bg-cream">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <!-- Section header -->
    <div class="mb-16">
      <div class="flex items-center gap-3 mb-4">
        <div class="h-px w-10 bg-red-600"></div>
        <span class="label-tag text-red-600">Acknowledgements</span>
      </div>
      <h2 class="font-display font-800 text-ink text-4xl lg:text-5xl mb-4">
        Our Sponsors
      </h2>
      <p class="font-body text-muted text-lg max-w-2xl">
        The 28th EMBL PhD Symposium is made possible by the generous support of our institutional and industry partners.
      </p>
    </div>

    <!-- Sponsors -->
    {mainSponsors.length > 0 && (
      <div class="sponsor-tier-group">
        <div class="tier-header">
          <h3 class="font-mono text-[0.65rem] tracking-[0.2em] uppercase font-600 text-green-800">Sponsors</h3>
          <div class="tier-line"></div>
        </div>
        <div class="sponsors-grid grid-sponsor">
          {mainSponsors.map((sponsor) => (
            <a
              href={sponsor.data.website}
              target="_blank"
              rel="noopener noreferrer"
              class="sponsor-card sponsor-main"
              title={sponsor.data.name}
            >
              <div class="sponsor-name font-display font-700">{sponsor.data.name}</div>
              <p class="sponsor-desc font-body text-sm text-muted">{sponsor.data.description}</p>
            </a>
          ))}
        </div>
      </div>
    )}

    <!-- Grants -->
    {grants.length > 0 && (
      <div class="sponsor-tier-group">
        <div class="tier-header">
          <h3 class="font-mono text-[0.65rem] tracking-[0.2em] uppercase font-600 text-green-800">Grants</h3>
          <div class="tier-line"></div>
        </div>
        <div class="sponsors-grid grid-grant">
          {grants.map((sponsor) => (
            <a
              href={sponsor.data.website}
              target="_blank"
              rel="noopener noreferrer"
              class="sponsor-card sponsor-grant"
              title={sponsor.data.name}
            >
              <div class="sponsor-name font-display font-700">{sponsor.data.name}</div>
              <p class="sponsor-desc font-body text-sm text-muted">{sponsor.data.description}</p>
            </a>
          ))}
        </div>
      </div>
    )}

    <!-- CPP Sponsors -->
    {cppSponsors.length > 0 && (
      <div class="sponsor-tier-group">
        <div class="tier-header">
          <h3 class="font-mono text-[0.65rem] tracking-[0.2em] uppercase font-600 text-green-800">CPP Sponsors</h3>
          <div class="tier-line"></div>
        </div>
        {cppSubTiers.map(({ key, label }) => cppGrouped[key]?.length > 0 && (
          <div class="cpp-subtier-group">
            <p class="font-mono text-[0.6rem] tracking-[0.15em] uppercase text-muted mb-3">{label}</p>
            <div class="sponsors-grid grid-cpp">
              {cppGrouped[key].map((sponsor) => (
                <a
                  href={sponsor.data.website}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="sponsor-card sponsor-cpp"
                  title={sponsor.data.name}
                >
                  <div class="sponsor-name font-display font-700">{sponsor.data.name}</div>
                  <p class="sponsor-desc font-body text-sm text-muted">{sponsor.data.description}</p>
                </a>
              ))}
            </div>
          </div>
        ))}
      </div>
    )}

    <!-- Become a sponsor CTA -->
    <div class="mt-16 pt-16 border-t border-warm">
      <div class="flex flex-col md:flex-row items-start md:items-center justify-between gap-6">
        <div>
          <h3 class="font-display font-700 text-xl text-ink mb-1">Interested in sponsoring?</h3>
          <p class="font-body text-muted">Contact us to discuss partnership opportunities for the symposium.</p>
        </div>
        <a
          href="mailto:phdsymposium2026.partners@embl.de"
          class="font-display font-700 text-sm px-8 py-4 bg-green-800 text-white hover:bg-green-900 transition-colors whitespace-nowrap"
        >
          Contact Us
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .sponsor-tier-group {
    margin-bottom: 3rem;
  }

  .cpp-subtier-group {
    margin-bottom: 2rem;
  }

  .tier-header {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }
  .tier-line {
    flex: 1;
    height: 1px;
    background: #D6D2CA;
  }

  .sponsors-grid {
    display: grid;
    gap: 1px;
    background: #D6D2CA;
    border: 1px solid #D6D2CA;
  }
  .grid-sponsor { grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); }
  .grid-grant   { grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); }
  .grid-cpp     { grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); }

  .sponsor-card {
    background: white;
    padding: 1.5rem 2rem;
    transition: background 0.2s, transform 0.2s;
    display: block;
  }
  .sponsor-card:hover {
    background: #F4F0E6;
    transform: translateY(-2px);
  }

  .sponsor-main  .sponsor-name { font-size: 1.15rem; color: #141414; }
  .sponsor-grant .sponsor-name { font-size: 1rem;    color: #141414; }
  .sponsor-cpp   .sponsor-name { font-size: 0.9rem;  color: #5A5857; }

  .sponsor-desc {
    margin-top: 0.5rem;
    line-height: 1.5;
  }
  .sponsor-cpp .sponsor-desc {
    display: none;
  }

  @media (max-width: 640px) {
    .grid-sponsor, .grid-grant, .grid-cpp {
      grid-template-columns: 1fr;
    }
  }
</style>
